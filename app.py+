from flask import Flask

app = Flask(__name__)

@app.route("/")
def home():
    return """
    <h1>Welcome to My Website</h1>
    <p>This website was built using Flask on my phone!</p>
    <a href="/about">About Me</a>
    """

@app.route("/about")
def about():
    return """
    <h1>About Me</h1>
    <p>Hi! I'm Kaviya, a B.Tech CSE student learning Python and Flask.</p>
    <a href="/">Home</a>
    """

app.run(host="0.0.0.0", port=5000)